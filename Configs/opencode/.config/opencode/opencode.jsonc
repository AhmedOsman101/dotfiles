{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "skills": {
    "paths": ["/home/othman/.agents/skills"]
  },
  "mcp": {
    "mgrep": {
      "type": "local",
      "command": ["mgrep", "mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
      "timeout": 5000,
      "enabled": false
    },
    "zod": {
      "type": "remote",
      "url": "https://mcp.inkeep.com/zod/mcp",
      "timeout": 5000,
      "enabled": false
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "timeout": 5000,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      },
      "enabled": false
    },
    "obsidian": {
      "type": "local",
      "command": ["uvx", "mcp-obsidian"],
      "environment": {
        "OBSIDIAN_API_KEY": "{env:OBSIDIAN_API_KEY}"
      },
      "enabled": false
    }
  },
  "plugin": [
    "cc-safety-net@latest",
    "@tarquinen/opencode-dcp@latest",
    "opencode-handoff@latest",
    "@plannotator/opencode@latest",
    "@iam-brain/opencode-codex-auth@latest",
    "envsitter-guard@latest", // prevents agents/tools from reading or editing sensitive .env* files
    "superpowers@git+https://github.com/obra/superpowers.git",
    "opentmux@latest",
    "opencode-agent-tmux@latest",
    [
      "@knikolov/opencode-plugin-simple-memory@latest",
      {
        "autoLoad": true,
        "autoSave": true,
        "autoHookTimeoutMs": 100,
        "contextLimit": 5,
        "contextMaxChars": 1200,
        "contextMinScore": 1,
        "autoSaveScope": "user"
      }
    ]
    // "@howaboua/opencode-planning-toolkit@latest" // planning toolkit for OpenCode
  ],
  "instructions": ["~/.config/opencode/plugin/shell-strategy/shell_strategy.md"]
}
