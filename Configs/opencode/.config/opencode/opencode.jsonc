{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "mgrep": {
      "type": "local",
      "command": ["mgrep", "mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
      "timeout": 10000,
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      },
      "enabled": true
    }
  },
  "plugin": [
    "cc-safety-net",
    "@tarquinen/opencode-dcp",
    "opencode-handoff",
    "@howaboua/opencode-planning-toolkit",
    "@plannotator/opencode"
  ],
  "instructions": [
    "~/.config/opencode/plugins/shell-strategy/shell_strategy.md"
  ]
}
