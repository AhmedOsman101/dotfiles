{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "mgrep": {
      "type": "local",
      "command": ["mgrep", "mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
      "timeout": 5000,
      "enabled": false
    },
    "zod": {
      "type": "remote",
      "url": "https://mcp.inkeep.com/zod/mcp",
      "timeout": 5000,
      "enabled": false
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      },
      "enabled": false
    },
    "obsidian": {
      "type": "local",
      "command": ["uvx", "mcp-obsidian"],
      "environment": {
        "OBSIDIAN_API_KEY": "{env:OBSIDIAN_API_KEY}"
      },
      "enabled": false
    }
  },
  "plugin": [
    "cc-safety-net@latest",
    "@tarquinen/opencode-dcp@latest",
    "opencode-handoff@latest",
    "@plannotator/opencode@latest",
    "@iam-brain/opencode-codex-auth@latest",
    "envsitter-guard@latest", // prevents agents/tools from reading or editing sensitive .env* files
    "@howaboua/opencode-planning-toolkit@latest" // planning toolkit for OpenCode
    // "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "instructions": [
    "~/.config/opencode/plugins/shell-strategy/shell_strategy.md"
  ],
  "provider": {
    "featherless": {
      "name": "Featherless",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.featherless.ai/v1",
        "apiKey": "{env:FEATHERLESS_API_KEY}"
      },
      "models": {
        "deepseek-ai/DeepSeek-V4-Pro": {
          "name": "DeepSeek-V4-Pro"
        },
        "moonshotai/Kimi-K2.6": {
          "name": "Kimi-K2.6"
        },
        "zai-org/GLM-5.1": {
          "name": "GLM-5.1"
        },
        "Qwen/Qwen3-Coder-Next": {
          "name": "Qwen3-Coder"
        },
        "AskVenice/venice-uncensored": {
          "name": "Venice Uncensored"
        }
      }
    }
  }
}
