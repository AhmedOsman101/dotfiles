{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "mgrep": {
      "type": "local",
      "command": ["mgrep", "mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
      "timeout": 10000,
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      },
      "enabled": true
    },
    "obsidian": {
      "type": "local",
      "command": ["uvx", "mcp-obsidian"],
      "environment": {
        "OBSIDIAN_API_KEY": "{env:OBSIDIAN_API_KEY}"
      },
      "enabled": true
    }
  },
  "plugin": [
    "cc-safety-net",
    "@tarquinen/opencode-dcp",
    "opencode-handoff",
    "@howaboua/opencode-planning-toolkit",
    "@plannotator/opencode"
  ],
  "instructions": [
    "~/.config/opencode/plugins/shell-strategy/shell_strategy.md"
  ],
  "provider": {
    "ollama": {
      "models": {
        "deepseek-r1:1.5b": {
          "name": "deepseek-r1:1.5b"
        },
        "qwen3:1.7b": {
          "name": "qwen3:1.7b"
        },
        "qwen3.5:0.8b": {
          "name": "qwen3.5:0.8b"
        }
      },
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  }
}
