{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "skills": {
    "paths": ["/home/othman/.agents/skills"]
  },
  "mcp": {
    "mgrep": {
      "type": "local",
      "command": ["mgrep", "mcp"],
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
      "timeout": 5000,
      "enabled": false
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "timeout": 5000,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      },
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "bunx",
        "chrome-devtools-mcp@latest",
        "--executable-path=/usr/bin/thorium-browser-avx2",
        "--no-usage-statistics"
      ],
      "enabled": false
    }
  },
  "plugin": [
    "cc-safety-net@latest",
    "@tarquinen/opencode-dcp@latest",
    "@tarquinen/opencode-smart-title@latest",
    "opencode-handoff@latest",
    // "@plannotator/opencode@latest",
    // "@iam-brain/opencode-codex-auth@latest",
    "envsitter-guard@latest", // prevents agents/tools from reading or editing sensitive .env* files
    // "superpowers@git+https://github.com/obra/superpowers.git",
    [
      "@knikolov/opencode-plugin-simple-memory@latest",
      {
        "autoLoad": true,
        "autoSave": true,
        "autoHookTimeoutMs": 100,
        "contextLimit": 10,
        "contextMaxChars": 1200,
        "contextMinScore": 1,
        "autoSaveScope": "user"
      }
    ]
    // "@howaboua/opencode-planning-toolkit@latest" // planning toolkit for OpenCode
  ],
  "provider": {
    "kiro": {
      "name": "Kiro Gateway",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:9001/v1",
        "apiKey": "{env:KIRO_PROXY_API_KEY}"
      },
      "models": {
        "auto-kiro": { "name": "Auto (Kiro)" },
        "claude-haiku-4.5": { "name": "Claude Haiku 4.5" },
        "claude-sonnet-4": { "name": "Claude Sonnet 4" },
        "claude-sonnet-4.5": { "name": "Claude Sonnet 4.5" },
        "claude-sonnet-4.6": { "name": "Claude Sonnet 4.6" },
        "claude-opus-4.5": { "name": "Claude Opus 4.5" },
        "claude-opus-4.6": { "name": "Claude Opus 4.6" },
        "claude-opus-4.7": { "name": "Claude Opus 4.7" },
        "deepseek-3.2": { "name": "DeepSeek V3.2" },
        "glm-5": { "name": "GLM-5" },
        "minimax-m2.1": { "name": "MiniMax M2.1" },
        "minimax-m2.5": { "name": "MiniMax M2.5" },
        "qwen3-coder-next": { "name": "Qwen3 Coder Next" }
      }
    },
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "hf.co/ewinregirgojr/MiniCPM5-1B-Agentic-Tooluse-GGUF:Q8_0": { "name": "MiniCPM 5" },
        "qwen3.5:0.8b": { "name": "Qwen 3.5 0.8B" },
        "deepseek-r1:1.5b": { "name": "DeepSeek R1 1.5B" },
        "qwen3:1.7b": { "name": "Qwen 3 1.7B" },
        "lfm2.5-thinking": { "name": "LFM 2.5 Thinking" },
        "qwen2.5-coder:0.5b": { "name": "Qwen 2.5 Coder 0.5B" }
      }
    },
    "llamacpp": {
      "name": "llama.cpp",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:9002/v1",
        "apiKey": "llamacpp"
      },
      "models": {
        "minicpm5-1b": { "name": "MiniCPM 5" },
        "qwen3.5-0.8b": { "name": "Qwen 3.5 0.8B" },
        "deepseek-r1-1.5b": { "name": "DeepSeek R1 1.5B" },
        "qwen3-1.7b": { "name": "Qwen 3 1.7B" },
        "lfm2.5-thinking": { "name": "LFM 2.5 Thinking" },
        "qwen2.5-coder-0.5b": { "name": "Qwen 2.5 Coder 0.5B" }
      }
    }
  },
  "instructions": []
}
