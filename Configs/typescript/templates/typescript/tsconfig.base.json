{
  // =====================================================================
  // tsconfig.base.json — DO NOT USE DIRECTLY. Extend from this file.
  //
  // This is the shared foundation for ALL TypeScript projects.
  // It contains: strict checks, linting rules, and module settings
  // that every TS project should have.
  //
  // Pick a variant instead:
  //   tsconfig.node.json            → Node.js app (tsc compiles)
  //   tsconfig.node-no-emit.json    → Node.js app (tsx/bun runs directly)
  //   tsconfig.library.json         → npm package you publish
  //   tsconfig.library-monorepo.json→ npm package inside a monorepo
  //   tsconfig.dom.json             → Browser app (Vite/Webpack/Next.js)
  // =====================================================================
  "compilerOptions": {
    // Language & Environment
    "target": "es2022",                          // Compile to ES2022

    // Modules
    "moduleDetection": "force",                  // Treat all .ts files as modules
    "isolatedModules": true,                     // Each file is transpiled independently
    "esModuleInterop": true,                     // Interop between CJS and ESM imports
    "allowSyntheticDefaultImports": true,        // Allow default imports from CJS modules
    "resolveJsonModule": true,                   // Allow importing .json files
    "verbatimModuleSyntax": true,                // Enforce explicit import/export syntax

    // Type Checking — Strict
    "strict": true,                              // Enable all strict type checks
    "noImplicitAny": true,                       // (auto-enabled by strict) Prevent implicit 'any' types
    "strictNullChecks": true,                    // (auto-enabled by strict) Enable strict null checks
    "strictFunctionTypes": true,                 // (auto-enabled by strict) Strict function type variance
    "strictBindCallApply": true,                 // (auto-enabled by strict) Strict check for bind/call/apply
    "noImplicitThis": true,                      // (auto-enabled by strict) Prevent implicit 'this' as 'any'
    "alwaysStrict": true,                        // (auto-enabled by strict) Parse in strict mode
    "skipLibCheck": true,                        // Skip type checking of .d.ts files

    // Linting
    "noUnusedLocals": true,                      // Error on unused local variables
    "noUnusedParameters": true,                  // Error on unused function parameters
    "allowUnusedLabels": false,                  // Disallow unused labels
    "noUncheckedSideEffectImports": true,        // Error on side-effect imports of non-existent modules
    "allowUnreachableCode": false,               // Error on unreachable code
    "noUncheckedIndexedAccess": true,            // Add undefined to index signatures
    "noPropertyAccessFromIndexSignature": true,  // Require bracket notation for index signatures
    "noImplicitOverride": true,                  // Require explicit override keyword
    "exactOptionalPropertyTypes": true,          // Distinguish between optional and undefined
    "noErrorTruncation": true,                   // Show full type errors (no truncation)

    // JavaScript
    "allowJs": false,                            // Do not allow .js files
    "checkJs": false                             // Do not type-check .js files
  }
}
